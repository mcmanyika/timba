# Firebase web app config (Firebase Console → Project settings → Your apps)
# Used by the browser AND server chat (inquiries, publication search).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenAI — server-only. Use OPENAI_API_KEY (not VITE_) so the key never ships to the browser.
OPENAI_API_KEY=
# Optional fallback if you already set VITE_OPENAI_API_KEY in Vercel (less secure):
# VITE_OPENAI_API_KEY=
# Optional — defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Optional
VITE_BUYMEACOFFEE_URL=https://www.buymeacoffee.com/jamesontimba
