rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userRoles() {
      return get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.roles;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/userRoles/$(request.auth.uid))
        && userRoles().hasAny(['admin']);
    }

    function isAdminOrEditor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/userRoles/$(request.auth.uid))
        && userRoles().hasAny(['admin', 'editor']);
    }

    function validUserRolesWrite() {
      return request.resource.data.keys().hasOnly(['roles'])
        && request.resource.data.roles is list
        && (
          request.resource.data.roles == ['admin']
          || request.resource.data.roles == ['editor']
        );
    }

    match /publications/{publicationId} {
      allow read: if resource.data.published == true || isAdminOrEditor();
      allow create, update, delete: if isAdminOrEditor();
    }

    match /subscribers/{email} {
      allow create: if !exists(/databases/$(database)/documents/subscribers/$(email))
        && request.resource.data.email == email
        && request.resource.data.first_name is string
        && request.resource.data.first_name.size() > 0
        && request.resource.data.first_name.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 255
        && request.resource.data.keys().hasOnly(['first_name', 'email', 'source', 'created_at'])
        && (request.resource.data.source == null || request.resource.data.source is string)
        && request.resource.data.created_at == request.time;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['email', 'created_at'])
        && request.resource.data.keys().hasOnly(['email', 'created_at'])
        && request.resource.data.email is string;
      allow update: if isAdmin()
        || (isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email'])
          && request.resource.data.email is string);
      allow delete: if isAdmin();
    }

    match /userRoles/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin() && validUserRolesWrite();
      allow delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isAdminOrEditor() || resource.data.status == 'approved';
      allow create: if request.resource.data.keys().hasOnly([
          'publication_id', 'publication_slug', 'publication_title',
          'author_name', 'author_email', 'body', 'status', 'created_at'
        ])
        && request.resource.data.publication_id is string
        && request.resource.data.publication_id.size() > 0
        && request.resource.data.publication_slug is string
        && request.resource.data.publication_slug.size() > 0
        && request.resource.data.publication_title is string
        && request.resource.data.publication_title.size() > 0
        && request.resource.data.publication_title.size() <= 300
        && request.resource.data.author_name is string
        && request.resource.data.author_name.size() > 0
        && request.resource.data.author_name.size() <= 100
        && request.resource.data.author_email is string
        && request.resource.data.author_email.size() > 0
        && request.resource.data.author_email.size() <= 255
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 2000
        && request.resource.data.status == 'pending'
        && request.resource.data.created_at == request.time;
      allow update, delete: if isAdminOrEditor();
    }

    match /publicationLikeCounts/{publicationId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count == 1;
      allow update: if request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count == resource.data.count + 1;
      allow delete: if false;
    }

    match /publicationLikeVotes/{voteId} {
      allow read: if false;
      allow create: if !exists(/databases/$(database)/documents/publicationLikeVotes/$(voteId))
        && request.resource.data.keys().hasOnly(['publication_id', 'visitor_id', 'created_at'])
        && request.resource.data.publication_id is string
        && request.resource.data.publication_id.size() > 0
        && request.resource.data.visitor_id is string
        && request.resource.data.visitor_id.size() > 0
        && voteId == request.resource.data.publication_id + '_' + request.resource.data.visitor_id
        && request.resource.data.created_at == request.time;
      allow update, delete: if false;
    }

    match /publicationViewCounts/{publicationId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count == 1;
      allow update: if request.resource.data.keys().hasOnly(['count'])
        && request.resource.data.count == resource.data.count + 1;
      allow delete: if false;
    }

    match /publicationViewSessions/{sessionId} {
      allow read: if false;
      allow create: if !exists(/databases/$(database)/documents/publicationViewSessions/$(sessionId))
        && request.resource.data.keys().hasOnly(['publication_id', 'visitor_id', 'created_at'])
        && request.resource.data.publication_id is string
        && request.resource.data.publication_id.size() > 0
        && request.resource.data.visitor_id is string
        && request.resource.data.visitor_id.size() > 0
        && sessionId == request.resource.data.publication_id + '_' + request.resource.data.visitor_id
        && request.resource.data.created_at == request.time;
      allow update, delete: if false;
    }

    match /articlePulse/{pulseId} {
      allow read: if isAdminOrEditor();
      allow create: if !exists(/databases/$(database)/documents/articlePulse/$(pulseId))
        && request.resource.data.keys().hasOnly([
          'publication_id', 'publication_slug', 'publication_title',
          'visitor_id', 'perspective_change', 'recommend', 'missing_note', 'created_at'
        ])
        && request.resource.data.publication_id is string
        && request.resource.data.publication_id.size() > 0
        && request.resource.data.publication_slug is string
        && request.resource.data.publication_slug.size() > 0
        && request.resource.data.publication_title is string
        && request.resource.data.publication_title.size() > 0
        && request.resource.data.publication_title.size() <= 300
        && request.resource.data.visitor_id is string
        && request.resource.data.visitor_id.size() > 0
        && pulseId == request.resource.data.publication_id + '_' + request.resource.data.visitor_id
        && request.resource.data.perspective_change in ['yes', 'somewhat', 'no']
        && request.resource.data.recommend is number
        && request.resource.data.recommend >= 1
        && request.resource.data.recommend <= 5
        && (request.resource.data.missing_note == null
          || (request.resource.data.missing_note is string
            && request.resource.data.missing_note.size() <= 500))
        && request.resource.data.created_at == request.time;
      allow update, delete: if false;
    }

    match /inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasOnly([
          'name', 'email', 'message', 'inquiry_type', 'organization', 'phone',
          'source_page', 'conversation_id', 'summary', 'status', 'created_at'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 255
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 5000
        && request.resource.data.inquiry_type in [
          'general', 'media', 'speaking', 'policy', 'subscription', 'other'
        ]
        && request.resource.data.status == 'new'
        && (request.resource.data.organization == null || request.resource.data.organization is string)
        && (request.resource.data.phone == null || request.resource.data.phone is string)
        && (request.resource.data.source_page == null || request.resource.data.source_page is string)
        && (request.resource.data.conversation_id == null || request.resource.data.conversation_id is string)
        && (request.resource.data.summary == null || request.resource.data.summary is string)
        && request.resource.data.created_at == request.time;
      allow read, update: if isAdmin();
      allow delete: if false;
    }
  }
}
